{
	"name": "galactic-sovereign-frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"openapi:generate:user-service": "rm -rf src/lib/api/user-service && npx swagger-typescript-api generate -p specs/user-service/openapi.yaml -o src/lib/api/user-service -n client.ts",
		"openapi:generate": "npm run openapi:generate:user-service",
		"dev": "npm run openapi:generate && vite dev",
		"build": "npm run openapi:generate && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"coverage": "TZ=UTC vitest run --coverage"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25",
		"@vitest/browser-playwright": "^4.1.6",
		"@vitest/coverage-v8": "^4.1.4",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.11",
		"swagger-typescript-api": "^13.9.1",
		"vitest": "^4.1.5",
		"vitest-browser-svelte": "^2.1.0"
	}
}
